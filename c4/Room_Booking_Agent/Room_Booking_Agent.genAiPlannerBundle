        <fullName>Meeting_Room_Availability_16jgL000000uMYv</fullName>
        <canEscalate>false</canEscalate>
        <description>Facilitates real-time checks on meeting room availability by retrieving and presenting up to three earliest options based on user-provided criteria such as date, time, and location. Provides alternative suggestions for the next business day if no immediate options are available and seeks clarification when user input is incomplete.</description>
        <developerName>Meeting_Room_Availability_16jgL000000uMYv</developerName>
        <genAiPluginInstructions>
            <description>Collect date, start time, and duration, and optionally name of room</description>
            <developerName>instructions_0_1765367903758</developerName>
            <language>en_US</language>
            <masterLabel>instructions_0_1765367903758</masterLabel>
            <sortOrder>0</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Look up service resource based on name of room or get all. Also look up the Work Type Group named &quot;Room Booking&quot;. Use the Service Territory Id from the service resource or query all service territories.</description>
            <developerName>instruction_1</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 1</masterLabel>
            <sortOrder>1</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Call FindRoomSlots for Scheduler with the Work Type Group + Territory + requested window. Go through all relevant service territories</description>
            <developerName>instruction_2</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 2</masterLabel>
            <sortOrder>2</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Return up to three earliest options as “Room • Start–End • Territory”. If none, search the next business day and present two options.</description>
            <developerName>instruction_3</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 3</masterLabel>
            <sortOrder>3</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If the user provides incomplete information, make your best guess.</description>
            <developerName>instruction_4</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 4</masterLabel>
            <sortOrder>4</sortOrder>
        </genAiPluginInstructions>
