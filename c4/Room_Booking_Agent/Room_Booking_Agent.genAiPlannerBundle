    <localTopics>
        <fullName>Room_Booking_16jgL000000uMYv</fullName>
        <canEscalate>false</canEscalate>
        <description>Manages the end-to-end process of booking a meeting room by confirming user preferences, verifying availability, and scheduling a single appointment. Resolves conflicts by re-querying availability and offering alternatives, while ensuring users receive a detailed confirmation of the booked room and appointment details.</description>
        <developerName>Room_Booking_16jgL000000uMYv</developerName>
        <genAiPluginInstructions>
            <description>Confirm the chosen room + time.</description>
            <developerName>instruction_1</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 1</masterLabel>
            <sortOrder>0</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Call Book Room Appointment with the slot and the selected Service Resource (room). &quot;Always use the 60 Minute Booking&quot; work type id not the work type group id. Query if needed. Always use the Serviceterritoryid of the room being booked. Always query  accounts with a limit of 1 and use the account id of the returned record for the parentid.</description>
            <developerName>instruction_2</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 2</masterLabel>
            <sortOrder>1</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If booking fails due to a conflict, re‑query time slots for the same window and present two alternatives.</description>
            <developerName>instruction_3</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 3</masterLabel>
            <sortOrder>2</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Summarize: “Booked [Room] on [Date] [Start–End] in [Building]; reference [Appointment Number/Id].”</description>
            <developerName>instruction_4</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 4</masterLabel>
            <sortOrder>3</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If no rooms are available, suggest alternative dates or options.</description>
            <developerName>instruction_5</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 5</masterLabel>
            <sortOrder>4</sortOrder>
        </genAiPluginInstructions>
