@isTest
private class CaseFollowUpAsyncKickoffTest {
    @TestSetup
        static void setupTestData() {
                Account testAccount = new Account(Name = 'Test Account');
                        insert testAccount;
                                Case testCase = new Case(
                                            Subject = 'Test Case for Follow-Up',
                                                        Description = 'Testing the async follow-up functionality',
                                                                    Status = 'New',
                                                                                Origin = 'Email',
                                                                                            AccountId = testAccount.Id
                                                                                                    );
                                                                                                            insert testCase;
                                                                                                                }
                                                                                                                    @isTest
                                                                                                                        static void testScheduleFollowUpWithDefaultDays() {
                                                                                                                                Case testCase = [SELECT Id FROM Case LIMIT 1];
                                                                                                                                        CaseFollowUpAsyncKickoff.KickoffRequest req = new CaseFollowUpAsyncKickoff.KickoffRequest();
                                                                                                                                                req.caseId = testCase.Id;
                                                                                                                                                        List<CaseFollowUpAsyncKickoff.KickoffRequest> requests = new List<CaseFollowUpAsyncKickoff.KickoffRequest>{ req };
                                                                                                                                                                Test.startTest();
                                                                                                                                                                        List<CaseFollowUpAsyncKickoff.KickoffResponse> responses = CaseFollowUpAsyncKickoff.scheduleFollowUp(requests);
                                                                                                                                                                                Test.stopTest();
                                                                                                                                                                                        System.assertEquals(1, responses.size(), 'Should return one response');
                                                                                                                                                                                                System.assertEquals(true, responses[0].success, 'Should be successful');
                                                                                                                                                                                                        System.assertNotEquals(null, responses[0].jobId, 'Should have a job ID');
                                                                                                                                                                                                                List<Task> tasks = [SELECT Id, Subject, ActivityDate FROM Task WHERE WhatId = :testCase.Id];
                                                                                                                                                                                                                        System.assertEquals(1, tasks.size(), 'Should create one task');
                                                                                                                                                                                                                                System.assert(tasks[0].Subject.contains('Follow-up'), 'Task subject should contain Follow-up');
                                                                                                                                                                                                                                        System.assertEquals(Date.today().addDays(7), tasks[0].ActivityDate, 'Default follow-up should be 7 days');
                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                @isTest
                                                                                                                                                                                                                                                    static void testScheduleFollowUpWithCustomDays() {
                                                                                                                                                                                                                                                            Case testCase = [SELECT Id FROM Case LIMIT 1];
                                                                                                                                                                                                                                                                    CaseFollowUpAsyncKickoff.KickoffRequest req = new CaseFollowUpAsyncKickoff.KickoffRequest();
                                                                                                                                                                                                                                                                            req.caseId = testCase.Id;
                                                                                                                                                                                                                                                                                    req.followUpDays = 14;
                                                                                                                                                                                                                                                                                            List<CaseFollowUpAsyncKickoff.KickoffRequest> requests = new List<CaseFollowUpAsyncKickoff.KickoffRequest>{ req };
                                                                                                                                                                                                                                                                                                    Test.startTest();
                                                                                                                                                                                                                                                                                                            List<CaseFollowUpAsyncKickoff.KickoffResponse> responses = CaseFollowUpAsyncKickoff.scheduleFollowUp(requests);
                                                                                                                                                                                                                                                                                                                    Test.stopTest();
                                                                                                                                                                                                                                                                                                                            System.assertEquals(true, responses[0].success, 'Should be successful');
                                                                                                                                                                                                                                                                                                                                    List<Task> tasks = [SELECT Id, ActivityDate FROM Task WHERE WhatId = :testCase.Id];
                                                                                                                                                                                                                                                                                                                                            System.assertEquals(1, tasks.size(), 'Should create one task');
                                                                                                                                                                                                                                                                                                                                                    System.assertEquals(Date.today().addDays(14), tasks[0].ActivityDate, 'Custom follow-up should be 14 days');
                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                            @isTest
                                                                                                                                                                                                                                                                                                                                                                static void testQueueableDirectExecution() {
                                                                                                                                                                                                                                                                                                                                                                        Case testCase = [SELECT Id FROM Case LIMIT 1];
                                                                                                                                                                                                                                                                                                                                                                                Test.startTest();
                                                                                                                                                                                                                                                                                                                                                                                        CaseFollowUpAsyncKickoff job = new CaseFollowUpAsyncKickoff(new List<Id>{ testCase.Id }, 3);
                                                                                                                                                                                                                                                                                                                                                                                                System.enqueueJob(job);
                                                                                                                                                                                                                                                                                                                                                                                                        Test.stopTest();
                                                                                                                                                                                                                                                                                                                                                                                                                List<Task> tasks = [SELECT Id, Subject, Description, Priority, Status FROM Task WHERE WhatId = :testCase.Id];
                                                                                                                                                                                                                                                                                                                                                                                                                        System.assertEquals(1, tasks.size(), 'Should create one task');
                                                                                                                                                                                                                                                                                                                                                                                                                                System.assertEquals('Normal', tasks[0].Priority, 'Priority should be Normal');
                                                                                                                                                                                                                                                                                                                                                                                                                                        System.assertEquals('Not Started', tasks[0].Status, 'Status should be Not Started');
                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                @isTest
                                                                                                                                                                                                                                                                                                                                                                                                                                                    static void testFollowUpTaskDetails() {
                                                                                                                                                                                                                                                                                                                                                                                                                                                            Case testCase = [SELECT Id, Subject, CaseNumber, OwnerId FROM Case LIMIT 1];
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Test.startTest();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            CaseFollowUpAsyncKickoff job = new CaseFollowUpAsyncKickoff(new List<Id>{ testCase.Id }, 5);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    System.enqueueJob(job);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            Test.stopTest();
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Task createdTask = [SELECT Id, Subject, Description, OwnerId, WhatId FROM Task WHERE WhatId = :testCase.Id LIMIT 1];
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            System.assertEquals(testCase.OwnerId, createdTask.OwnerId, 'Task owner should match case owner');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    System.assertEquals(testCase.Id, createdTask.WhatId, 'Task should be related to case');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            System.assert(createdTask.Subject.contains('Follow-up'), 'Subject should contain Follow-up');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    System.assert(createdTask.Description.contains(testCase.CaseNumber), 'Description should contain case number');
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }