public class CaseFollowUpAsyncKickoff implements Queueable {
    private List<Id> caseIds;
        private Integer followUpDays;
            public CaseFollowUpAsyncKickoff(List<Id> caseIds, Integer followUpDays) {
                    this.caseIds = caseIds;
                            this.followUpDays = followUpDays;
                                }
                                    public void execute(QueueableContext context) {
                                            List<Task> tasksToCreate = new List<Task>();
                                                    List<Case> cases = [SELECT Id, OwnerId, Subject, CaseNumber FROM Case WHERE Id IN :caseIds];
                                                            for (Case c : cases) {
                                                                        Task followUpTask = new Task();
                                                                                    followUpTask.WhatId = c.Id;
                                                                                                followUpTask.OwnerId = c.OwnerId;
                                                                                                            followUpTask.Subject = 'Follow-up: ' + c.Subject;
                                                                                                                        followUpTask.Description = 'Automated follow-up task for Case ' + c.CaseNumber;
                                                                                                                                    followUpTask.ActivityDate = Date.today().addDays(followUpDays);
                                                                                                                                                followUpTask.Priority = 'Normal';
                                                                                                                                                            followUpTask.Status = 'Not Started';
                                                                                                                                                                        tasksToCreate.add(followUpTask);
                                                                                                                                                                                }
                                                                                                                                                                                        if (!tasksToCreate.isEmpty()) {
                                                                                                                                                                                                    insert tasksToCreate;
                                                                                                                                                                                                            }
                                                                                                                                                                                                                }
                                                                                                                                                                                                                    @InvocableMethod(label='Schedule Case Follow-Up' description='Queues async job to create follow-up tasks for cases')
                                                                                                                                                                                                                        public static List<KickoffResponse> scheduleFollowUp(List<KickoffRequest> requests) {
                                                                                                                                                                                                                                List<KickoffResponse> responses = new List<KickoffResponse>();
                                                                                                                                                                                                                                        for (KickoffRequest req : requests) {
                                                                                                                                                                                                                                                    KickoffResponse res = new KickoffResponse();
                                                                                                                                                                                                                                                                try {
                                                                                                                                                                                                                                                                                Integer days = req.followUpDays != null ? req.followUpDays : 7;
                                                                                                                                                                                                                                                                                                Id jobId = System.enqueueJob(new CaseFollowUpAsyncKickoff(new List<Id>{ req.caseId }, days));
                                                                                                                                                                                                                                                                                                                res.jobId = jobId;
                                                                                                                                                                                                                                                                                                                                res.success = true;
                                                                                                                                                                                                                                                                                                                                                res.message = 'Follow-up job queued successfully';
                                                                                                                                                                                                                                                                                                                                                            } catch (Exception e) {
                                                                                                                                                                                                                                                                                                                                                                            res.success = false;
                                                                                                                                                                                                                                                                                                                                                                                            res.message = 'Error: ' + e.getMessage();
                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                    responses.add(res);
                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                    return responses;
                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                            public class KickoffRequest {
                                                                                                                                                                                                                                                                                                                                                                                                                                                    @InvocableVariable(label='Case ID' required=true)
                                                                                                                                                                                                                                                                                                                                                                                                                                                            public Id caseId;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                    @InvocableVariable(label='Follow-Up Days' description='Number of days until follow-up (default: 7)')
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            public Integer followUpDays;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    public class KickoffResponse {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            @InvocableVariable(label='Job ID')
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    public Id jobId;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            @InvocableVariable(label='Success')
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    public Boolean success;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            @InvocableVariable(label='Message')
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    public String message;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        }