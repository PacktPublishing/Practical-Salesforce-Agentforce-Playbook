@isTest
private class CaseTriageActionTest {
    @isTest
        static void testTriageCriticalCase() {
                CaseTriageAction.TriageRequest req = new CaseTriageAction.TriageRequest();
                        req.caseSubject = 'CRITICAL: System Down';
                                req.caseDescription = 'The entire system is down and we cannot process orders.';
                                        req.caseOrigin = 'Email';
                                                List<CaseTriageAction.TriageRequest> requests = new List<CaseTriageAction.TriageRequest>{ req };
                                                        Test.startTest();
                                                                List<CaseTriageAction.TriageResponse> responses = CaseTriageAction.triage(requests);
                                                                        Test.stopTest();
                                                                                System.assertEquals(1, responses.size(), 'Should return one response');
                                                                                        System.assertEquals('Critical', responses[0].suggestedPriority, 'Priority should be Critical');
                                                                                                System.assertEquals(true, responses[0].requiresEscalation, 'Should require escalation');
                                                                                                    }
