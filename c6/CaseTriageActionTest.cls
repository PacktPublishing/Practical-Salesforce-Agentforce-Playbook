                                                                                                                                                                    List<CaseTriageAction.TriageResponse> responses = CaseTriageAction.triage(requests);
                                                                                                                                                                            Test.stopTest();
                                                                                                                                                                                    System.assertEquals('High', responses[0].suggestedPriority, 'Priority should be High');
                                                                                                                                                                                            System.assertEquals('Billing Support', responses[0].suggestedQueue, 'Queue should be Billing Support');
                                                                                                                                                                                                }
